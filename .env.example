# Database Configuration
# PostgreSQL connection string - required
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/excelidraw_db"

# Backend Ports (optional - defaults to 3002 for HTTP, 8080 for WS)
# HTTP_PORT=3002
# WS_PORT=8080

# JWT Secret (IMPORTANT - use a strong, random secret in production)
JWT_SECRET="your_super_secret_jwt_key_change_in_production"

# Frontend API Configuration (optional - only needed for non-localhost deployments)
# NEXT_PUBLIC_API_HOST=api.example.com
# NEXT_PUBLIC_API_PORT=3002
# NEXT_PUBLIC_WS_HOST=ws.example.com
# NEXT_PUBLIC_WS_PORT=8080
# NEXT_PUBLIC_API_URL=https://api.example.com  # Full URL for production
# NEXT_PUBLIC_WS_URL=wss://ws.example.com      # Full WebSocket URL for production
