# Database Configuration
# PostgreSQL connection string - required for Prisma migrations and client generation
# Format: postgresql://username:password@host:port/database_name
# Default username is 'postgres' - set password during PostgreSQL installation
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/excelidraw_db"

# For local development with default PostgreSQL setup:
# DATABASE_URL="postgresql://postgres:mahes@localhost:5432/excelidraw_db"